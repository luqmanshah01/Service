<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

{%- style -%}
  /* ── WRAPPER ── */
  #hs-{{ section.id }} {
    position: relative;
    width: 100%;
    height: 90vh;
    min-height: 500px;
    overflow: hidden;
  }

  /* ── SLIDES ── */
  #hs-{{ section.id }} .hs-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.7s ease;
    pointer-events: none;
  }

  #hs-{{ section.id }} .hs-slide.active {
    opacity: 1;
    pointer-events: all;
    z-index: 1;
  }

  /* ── PER-SLIDE BACKGROUND ── */
  {%- for block in section.blocks -%}
    #hs-{{ section.id }} .hs-slide[data-block="{{ block.id }}"] {
      background: {{ block.settings.bg_color }};
    }
  {%- endfor -%}

  /* ── CONTENT ── */
  #hs-{{ section.id }} .hs-content {
    width: 100%;
    padding: 0 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  /* ── HEADLINE ── */
  #hs-{{ section.id }} .hs-headline {
    font-family: 'Oswald', sans-serif;
    font-weight: 300;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: -2px;
    margin: 0;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease 0.2s, transform 0.7s ease 0.2s;
  }

  #hs-{{ section.id }} .hs-slide.active .hs-headline {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── PER-SLIDE TEXT SIZES & COLORS ── */
  {%- for block in section.blocks -%}
    #hs-{{ section.id }} .hs-slide[data-block="{{ block.id }}"] .hs-headline {
      font-size: {{ block.settings.headline_size }}px;
      color: {{ block.settings.text_color }};
    }
    #hs-{{ section.id }} .hs-slide[data-block="{{ block.id }}"] .hs-eyebrow {
      font-size: {{ block.settings.eyebrow_size }}px;
      color: {{ block.settings.text_color }};
    }
    #hs-{{ section.id }} .hs-slide[data-block="{{ block.id }}"] .hs-subline {
      font-size: {{ block.settings.subline_size }}px;
      color: {{ block.settings.text_color }};
    }
    #hs-{{ section.id }} .hs-slide[data-block="{{ block.id }}"] .hs-cta {
      border-color: {{ block.settings.text_color }};
      color: {{ block.settings.text_color }};
    }
    #hs-{{ section.id }} .hs-slide[data-block="{{ block.id }}"] .hs-cta:hover {
      background: {{ block.settings.text_color }};
      color: {{ block.settings.bg_color }};
    }
  {%- endfor -%}

  /* ── EYEBROW ── */
  #hs-{{ section.id }} .hs-eyebrow {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    letter-spacing: 5px;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: block;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease 0.1s, transform 0.6s ease 0.1s;
  }
  #hs-{{ section.id }} .hs-slide.active .hs-eyebrow {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── SUBLINE ── */
  #hs-{{ section.id }} .hs-subline {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    margin-top: 20px;
    margin-bottom: 0;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease 0.35s, transform 0.6s ease 0.35s;
  }
  #hs-{{ section.id }} .hs-slide.active .hs-subline {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── CTA ── */
  #hs-{{ section.id }} .hs-cta {
    display: inline-block;
    margin-top: 36px;
    padding: 14px 44px;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid;
    background: transparent;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease;
    opacity: 0;
    transform: translateY(20px);
    transition: background 0.3s ease, color 0.3s ease,
                opacity 0.6s ease 0.5s, transform 0.6s ease 0.5s;
  }
  #hs-{{ section.id }} .hs-slide.active .hs-cta {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── DOTS ── */
  #hs-{{ section.id }} .hs-dots {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 12px;
    align-items: center;
  }

  #hs-{{ section.id }} .hs-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.6);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  #hs-{{ section.id }} .hs-dot.active {
    background: #fff;
    border-color: #fff;
    transform: scale(1.2);
  }

  /* ── ARROWS ── */
  #hs-{{ section.id }} .hs-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 10px;
    opacity: 0.6;
    transition: opacity 0.2s;
    line-height: 0;
  }
  #hs-{{ section.id }} .hs-arrow:hover { opacity: 1; }
  #hs-{{ section.id }} .hs-arrow svg  { width: 28px; height: 28px; display: block; }
  #hs-{{ section.id }} .hs-prev { left: 18px; }
  #hs-{{ section.id }} .hs-next { right: 18px; }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    #hs-{{ section.id }} {
      height: 60vw;
      min-height: 300px;
    }
    #hs-{{ section.id }} .hs-slide {
      position: absolute;
    }
    #hs-{{ section.id }} .hs-content { padding: 0 20px; }
    #hs-{{ section.id }} .hs-arrow   { display: none; }
    #hs-{{ section.id }} .hs-dots    { bottom: 14px; }
    #hs-{{ section.id }} .hs-dot     { width: 7px; height: 7px; }
  }
{%- endstyle -%}

<div id="hs-{{ section.id }}" aria-label="Hero Slider">

  {%- assign slide_num = 0 -%}
  {%- for block in section.blocks -%}
    {%- assign slide_num = slide_num | plus: 1 -%}
    <div
      class="hs-slide{% if forloop.first %} active{% endif %}"
      role="group"
      aria-label="Slide {{ slide_num }} of {{ section.blocks.size }}"
      data-block="{{ block.id }}"
      {{ block.shopify_attributes }}
    >
      <div class="hs-content">
        {%- if block.settings.eyebrow != blank -%}
          <span class="hs-eyebrow">{{ block.settings.eyebrow }}</span>
        {%- endif -%}

        {%- if block.settings.headline != blank -%}
          <h2 class="hs-headline">{{ block.settings.headline | upcase }}</h2>
        {%- endif -%}

        {%- if block.settings.subline != blank -%}
          <p class="hs-subline">{{ block.settings.subline }}</p>
        {%- endif -%}

        {%- if block.settings.button_label != blank -%}
          <a href="{{ block.settings.button_link }}" class="hs-cta">
            {{ block.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}

  <!-- Arrows -->
  <button class="hs-arrow hs-prev" id="hs-prev-{{ section.id }}" aria-label="Previous slide">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>
  <button class="hs-arrow hs-next" id="hs-next-{{ section.id }}" aria-label="Next slide">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>

  <!-- Dots -->
  <div class="hs-dots" id="hs-dots-{{ section.id }}" role="tablist">
    {%- for block in section.blocks -%}
      <button
        class="hs-dot{% if forloop.first %} active{% endif %}"
        role="tab"
        aria-selected="{{ forloop.first }}"
        aria-label="Slide {{ forloop.index }}"
      ></button>
    {%- endfor -%}
  </div>

</div>

<script>
(function(){
  var wrap    = document.getElementById('hs-{{ section.id }}');
  var slides  = Array.from(wrap.querySelectorAll('.hs-slide'));
  var dots    = Array.from(wrap.querySelectorAll('.hs-dot'));
  var prevBtn = document.getElementById('hs-prev-{{ section.id }}');
  var nextBtn = document.getElementById('hs-next-{{ section.id }}');
  var current = 0;
  var timer   = null;

  function getTextColor(idx) {
    var s = slides[idx];
    var h = s.querySelector('.hs-headline');
    if (!h) return '#fff';
    return getComputedStyle(h).color;
  }

  function goTo(idx) {
    var prev = current;
    current = ((idx % slides.length) + slides.length) % slides.length;
    if (prev === current) return;

    /* Reset incoming slide text so animation re-fires */
    slides[current].querySelectorAll('.hs-headline,.hs-eyebrow,.hs-subline,.hs-cta').forEach(function(el){
      el.style.transition = 'none';
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
    });

    slides[prev].classList.remove('active');

    requestAnimationFrame(function(){
      requestAnimationFrame(function(){
        slides[current].querySelectorAll('.hs-headline,.hs-eyebrow,.hs-subline,.hs-cta').forEach(function(el){
          el.style.transition = '';
          el.style.opacity = '';
          el.style.transform = '';
        });
        slides[current].classList.add('active');
        updateUI();
      });
    });
  }

  function updateUI() {
    var bgColor   = slides[current].style.background ||
                    getComputedStyle(slides[current]).backgroundColor;
    var textColor = getTextColor(current);

    dots.forEach(function(d, i){
      var active = i === current;
      d.classList.toggle('active', active);
      d.setAttribute('aria-selected', String(active));
      d.style.background   = active ? textColor : 'transparent';
      d.style.borderColor  = active ? textColor : 'rgba(255,255,255,0.55)';
    });

    [prevBtn, nextBtn].forEach(function(b){ b.style.color = textColor; });
  }

  function start(){ timer = setInterval(function(){ goTo(current + 1); }, 4000); }
  function reset(){ clearInterval(timer); start(); }

  prevBtn.addEventListener('click', function(){ goTo(current - 1); reset(); });
  nextBtn.addEventListener('click', function(){ goTo(current + 1); reset(); });
  dots.forEach(function(d, i){ d.addEventListener('click', function(){ goTo(i); reset(); }); });

  var tx = 0;
  wrap.addEventListener('touchstart', function(e){ tx = e.touches[0].clientX; }, { passive: true });
  wrap.addEventListener('touchend', function(e){
    var dx = tx - e.changedTouches[0].clientX;
    if (Math.abs(dx) > 50){ goTo(dx > 0 ? current + 1 : current - 1); reset(); }
  }, { passive: true });

  wrap.addEventListener('mouseenter', function(){ clearInterval(timer); });
  wrap.addEventListener('mouseleave', start);

  updateUI();
  start();
})();
</script>

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "class": "section hero-slider-section",
  "max_blocks": 5,
  "disabled_on": { "groups": ["header", "footer"] },
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background colour",
          "default": "#E8402A"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text colour",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Top label (leave blank to hide)"
        },
        {
          "type": "range",
          "id": "eyebrow_size",
          "label": "Top label size",
          "min": 8, "max": 24, "step": 1, "unit": "px", "default": 13
        },
        {
          "type": "text",
          "id": "headline",
          "label": "Headline",
          "default": "SUMMER SALE"
        },
        {
          "type": "range",
          "id": "headline_size",
          "label": "Headline size",
          "min": 40, "max": 200, "step": 2, "unit": "px", "default": 160
        },
        {
          "type": "text",
          "id": "subline",
          "label": "Subline (leave blank to hide)"
        },
        {
          "type": "range",
          "id": "subline_size",
          "label": "Subline size",
          "min": 12, "max": 48, "step": 1, "unit": "px", "default": 20
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label (leave blank to hide)"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "bg_color": "#E8402A",
            "text_color": "#ffffff",
            "headline": "SUMMER SALE",
            "headline_size": 160
          }
        }
      ]
    }
  ]
}
{% endschema %}

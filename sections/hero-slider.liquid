{{ 'hero-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #hero-slider-{{ section.id }} {
    position: relative;
    width: 100%;
    height: 90vh;
    min-height: 560px;
    overflow: hidden;
  }

  #hero-slider-{{ section.id }} .hs-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: row;
    opacity: 0;
    transition: opacity 0.65s ease;
    pointer-events: none;
  }

  #hero-slider-{{ section.id }} .hs-slide.active {
    opacity: 1;
    pointer-events: all;
    z-index: 1;
  }

  #hero-slider-{{ section.id }} .hs-left {
    width: 50%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 60px 60px 90px;
  }

  #hero-slider-{{ section.id }} .hs-right {
    width: 50%;
    height: 100%;
    overflow: hidden;
    flex-shrink: 0;
  }

  #hero-slider-{{ section.id }} .hs-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #hero-slider-{{ section.id }} .ta {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  #hero-slider-{{ section.id }} .hs-slide.active .ta { opacity: 1; transform: translateY(0); }
  #hero-slider-{{ section.id }} .hs-slide.active .ta:nth-child(1) { transition-delay: 0.35s; }
  #hero-slider-{{ section.id }} .hs-slide.active .ta:nth-child(2) { transition-delay: 0.50s; }
  #hero-slider-{{ section.id }} .hs-slide.active .ta:nth-child(3) { transition-delay: 0.65s; }
  #hero-slider-{{ section.id }} .hs-slide.active .ta:nth-child(4) { transition-delay: 0.80s; }

  #hero-slider-{{ section.id }} .hs-eyebrow {
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 300;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 14px;
    display: block;
  }

  #hero-slider-{{ section.id }} .hs-headline {
    font-family: 'Oswald', sans-serif;
    font-size: 88px;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 0.92;
    margin-bottom: 22px;
    letter-spacing: -1px;
  }

  #hero-slider-{{ section.id }} .hs-subline {
    font-family: 'Poppins', sans-serif;
    font-size: 22px;
    font-weight: 400;
    margin-bottom: 44px;
  }

  #hero-slider-{{ section.id }} .hs-cta {
    display: inline-block;
    padding: 14px 42px;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid;
    background: transparent;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease;
    align-self: flex-start;
    line-height: 1;
  }

  /* Slide 1 — Red */
  #hero-slider-{{ section.id }} .hs-slide-1         { background: #E8002D; }
  #hero-slider-{{ section.id }} .hs-slide-1 .hs-left { color: #fff; }
  #hero-slider-{{ section.id }} .hs-slide-1 .hs-cta  { border-color: #fff; color: #fff; }
  #hero-slider-{{ section.id }} .hs-slide-1 .hs-cta:hover { background: #fff; color: #E8002D; }

  /* Slide 2 — Black */
  #hero-slider-{{ section.id }} .hs-slide-2         { background: #111111; }
  #hero-slider-{{ section.id }} .hs-slide-2 .hs-left { color: #fff; }
  #hero-slider-{{ section.id }} .hs-slide-2 .hs-cta  { border-color: #fff; color: #fff; }
  #hero-slider-{{ section.id }} .hs-slide-2 .hs-cta:hover { background: #fff; color: #111111; }

  /* Slide 3 — Cream */
  #hero-slider-{{ section.id }} .hs-slide-3         { background: #F5F0E8; }
  #hero-slider-{{ section.id }} .hs-slide-3 .hs-left { color: #111111; }
  #hero-slider-{{ section.id }} .hs-slide-3 .hs-cta  { border-color: #111111; color: #111111; }
  #hero-slider-{{ section.id }} .hs-slide-3 .hs-cta:hover { background: #111111; color: #F5F0E8; }

  /* Arrows */
  #hero-slider-{{ section.id }} .hs-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 12px;
    color: #fff;
    opacity: 0.75;
    transition: opacity 0.2s, color 0.3s;
    line-height: 0;
  }
  #hero-slider-{{ section.id }} .hs-arrow:hover { opacity: 1; }
  #hero-slider-{{ section.id }} .hs-arrow svg { width: 30px; height: 30px; display: block; }
  #hero-slider-{{ section.id }} .hs-prev { left: 20px; }
  #hero-slider-{{ section.id }} .hs-next { right: 20px; }

  /* Dots */
  #hero-slider-{{ section.id }} .hs-dots {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 10px;
    align-items: center;
  }

  #hero-slider-{{ section.id }} .hs-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.45);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, transform 0.3s;
  }

  #hero-slider-{{ section.id }} .hs-dot.active {
    background: #fff;
    transform: scale(1.35);
  }

  /* Mobile */
  @media (max-width: 768px) {
    #hero-slider-{{ section.id }} {
      height: auto;
      min-height: auto;
    }
    #hero-slider-{{ section.id }} .hs-slide {
      position: relative;
      flex-direction: column-reverse;
      opacity: 1;
      pointer-events: all;
      display: none;
    }
    #hero-slider-{{ section.id }} .hs-slide.active { display: flex; }
    #hero-slider-{{ section.id }} .hs-left {
      width: 100%;
      height: auto;
      padding: 36px 28px 44px;
    }
    #hero-slider-{{ section.id }} .hs-right {
      width: 100%;
      height: 48vw;
      min-height: 220px;
      max-height: 340px;
    }
    #hero-slider-{{ section.id }} .hs-headline { font-size: 50px; }
    #hero-slider-{{ section.id }} .hs-subline  { font-size: 17px; margin-bottom: 28px; }
    #hero-slider-{{ section.id }} .hs-eyebrow  { font-size: 11px; letter-spacing: 3px; margin-bottom: 10px; }
    #hero-slider-{{ section.id }} .hs-cta      { font-size: 11px; padding: 12px 26px; letter-spacing: 2px; }
    #hero-slider-{{ section.id }} .ta          { opacity: 1; transform: none; transition: none; }
    #hero-slider-{{ section.id }} .hs-arrow    { display: none; }
    #hero-slider-{{ section.id }} .hs-dots     { bottom: 14px; }
  }

  @media (max-width: 480px) {
    #hero-slider-{{ section.id }} .hs-headline { font-size: 38px; }
    #hero-slider-{{ section.id }} .hs-subline  { font-size: 15px; }
    #hero-slider-{{ section.id }} .hs-left     { padding: 28px 20px 36px; }
  }
{%- endstyle -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Poppins:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">

<div id="hero-slider-{{ section.id }}" aria-label="Featured promotions">

  {%- assign slide_num = 0 -%}
  {%- for block in section.blocks -%}
    {%- assign slide_num = slide_num | plus: 1 -%}
    {%- assign is_light = false -%}
    {%- if block.settings.text_color == 'dark' -%}
      {%- assign is_light = true -%}
    {%- endif -%}

    <div
      class="hs-slide hs-slide-{{ slide_num }}{% if forloop.first %} active{% endif %}"
      role="group"
      aria-label="Slide {{ slide_num }} of {{ section.blocks.size }}"
      data-light="{{ is_light }}"
      {{ block.shopify_attributes }}
    >
      <div class="hs-left">
        <span class="hs-eyebrow ta">{{ block.settings.eyebrow }}</span>
        <h2 class="hs-headline ta">{{ block.settings.headline | newline_to_br }}</h2>
        <p class="hs-subline ta">{{ block.settings.subline }}</p>
        <a href="{{ block.settings.button_link }}" class="hs-cta ta">{{ block.settings.button_label }}</a>
      </div>
      <div class="hs-right">
        {%- if block.settings.image != blank -%}
          {{
            block.settings.image
            | image_url: width: 900
            | image_tag:
              loading: forloop.first | ternary: 'eager', 'lazy',
              widths: '400, 600, 800, 900',
              sizes: '50vw',
              alt: block.settings.headline
          }}
        {%- else -%}
          <img
            src="{{ block.settings.placeholder_url }}"
            alt="{{ block.settings.headline }}"
            loading="{{ forloop.first | ternary: 'eager', 'lazy' }}"
          >
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}

  <!-- Prev / Next -->
  <button class="hs-arrow hs-prev" id="hs-prev-{{ section.id }}" aria-label="Previous slide">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>
  <button class="hs-arrow hs-next" id="hs-next-{{ section.id }}" aria-label="Next slide">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>

  <!-- Dots -->
  <div class="hs-dots" id="hs-dots-{{ section.id }}" role="tablist" aria-label="Slide indicators">
    {%- for block in section.blocks -%}
      <button
        class="hs-dot{% if forloop.first %} active{% endif %}"
        role="tab"
        aria-selected="{{ forloop.first }}"
        aria-label="Slide {{ forloop.index }}"
      ></button>
    {%- endfor -%}
  </div>

</div>

<script>
(function() {
  var wrap    = document.getElementById('hero-slider-{{ section.id }}');
  var slides  = Array.from(wrap.querySelectorAll('.hs-slide'));
  var dots    = Array.from(wrap.querySelectorAll('.hs-dot'));
  var prevBtn = document.getElementById('hs-prev-{{ section.id }}');
  var nextBtn = document.getElementById('hs-next-{{ section.id }}');
  var current = 0;
  var timer   = null;
  var isMob   = window.innerWidth <= 768;

  window.addEventListener('resize', function(){ isMob = window.innerWidth <= 768; });

  function goTo(idx) {
    var prev = current;
    current = ((idx % slides.length) + slides.length) % slides.length;
    if (prev === current) return;

    if (!isMob) {
      var textEls = slides[current].querySelectorAll('.ta');
      textEls.forEach(function(el) {
        el.style.transition = 'none';
        el.style.opacity    = '0';
        el.style.transform  = 'translateY(32px)';
      });
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          textEls.forEach(function(el) {
            el.style.transition = '';
            el.style.opacity    = '';
            el.style.transform  = '';
          });
          slides[prev].classList.remove('active');
          slides[current].classList.add('active');
          updateUI();
        });
      });
    } else {
      slides[prev].classList.remove('active');
      slides[current].classList.add('active');
      updateUI();
    }
  }

  function updateUI() {
    var isLight = slides[current].dataset.light === 'true';
    dots.forEach(function(d, i) {
      var active = i === current;
      d.classList.toggle('active', active);
      d.setAttribute('aria-selected', active);
      d.style.background = active
        ? (isLight ? '#111' : '#fff')
        : (isLight ? 'rgba(0,0,0,0.28)' : 'rgba(255,255,255,0.45)');
    });
    [prevBtn, nextBtn].forEach(function(btn) {
      btn.style.color = isLight ? '#111' : '#fff';
    });
  }

  function start() { timer = setInterval(function(){ goTo(current + 1); }, 4000); }
  function reset() { clearInterval(timer); start(); }

  prevBtn.addEventListener('click', function(){ goTo(current - 1); reset(); });
  nextBtn.addEventListener('click', function(){ goTo(current + 1); reset(); });
  dots.forEach(function(d, i){ d.addEventListener('click', function(){ goTo(i); reset(); }); });

  /* Touch swipe */
  var tx = 0;
  wrap.addEventListener('touchstart', function(e){ tx = e.touches[0].clientX; }, { passive: true });
  wrap.addEventListener('touchend', function(e) {
    var dx = tx - e.changedTouches[0].clientX;
    if (Math.abs(dx) > 50) { goTo(dx > 0 ? current + 1 : current - 1); reset(); }
  }, { passive: true });

  /* Pause on hover */
  wrap.addEventListener('mouseenter', function(){ clearInterval(timer); });
  wrap.addEventListener('mouseleave', start);

  updateUI();
  start();
})();
</script>

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "class": "section hero-slider-section",
  "max_blocks": 5,
  "disabled_on": { "groups": ["header", "footer"] },
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image (right side)"
        },
        {
          "type": "text",
          "id": "placeholder_url",
          "label": "Placeholder image URL (if no image uploaded)",
          "default": "https://placehold.co/800x900/E8002D/ffffff?text=Model"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Top label (small text)",
          "default": "New Arrivals"
        },
        {
          "type": "textarea",
          "id": "headline",
          "label": "Headline (use newline for line break)",
          "default": "SUMMER\nEDIT"
        },
        {
          "type": "text",
          "id": "subline",
          "label": "Subline",
          "default": "Upto 50% Off"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "text_color",
          "label": "Text colour",
          "options": [
            { "value": "light", "label": "White (dark background)" },
            { "value": "dark",  "label": "Dark (light background)" }
          ],
          "default": "light"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "placeholder_url": "https://placehold.co/800x900/E8002D/ffffff?text=Model",
            "eyebrow": "New Arrivals",
            "headline": "SUMMER\nEDIT",
            "subline": "Upto 50% Off",
            "button_label": "Shop Now",
            "text_color": "light"
          }
        },
        {
          "type": "slide",
          "settings": {
            "placeholder_url": "https://placehold.co/800x900/111111/ffffff?text=Collection",
            "eyebrow": "Exclusive Drop",
            "headline": "MEN'S\nCOLLECTION",
            "subline": "Starting from PKR 1,999",
            "button_label": "Explore Now",
            "text_color": "light"
          }
        },
        {
          "type": "slide",
          "settings": {
            "placeholder_url": "https://placehold.co/800x900/F5F0E8/333333?text=Women",
            "eyebrow": "Women's Fashion",
            "headline": "FRESH\nLOOKS",
            "subline": "New Season Styles",
            "button_label": "Discover Now",
            "text_color": "dark"
          }
        }
      ]
    }
  ]
}
{% endschema %}
